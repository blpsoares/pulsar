{
  "name": "mongo-pulsar",
  "module": "./src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "bun ./src/app.ts",
    "up:db": "docker-compose up --build -d",
    "down:db": "docker-compose down",
    "clean:container": "docker rm -f $(docker ps -a -q) && docker rmi -f mongo-pulsar_mongo",
    "populate:db": "bun docker/populate-fakedb/src/app.js"
  },
  "devDependencies": {
    "@types/bun": "1.1.10",
    "@types/chalk": "^2.2.0",
    "@types/cli-progress": "^3.11.6",
    "@types/commander": "^2.12.2",
    "@types/figlet": "^1.5.8",
    "@types/mongodb": "^4.0.7"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "figlet": "^1.7.0",
    "mongodb": "^6.9.0"
  }
}
