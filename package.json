{
	"name": "pulsar",
	"version": "1.0.0",
	"module": "./src/cli.ts",
	"type": "module",
	"bin": {
		"pulsar": "./src/cli.ts"
	},
	"scripts": {
		"test": "bun test",
                "compose:limit":"docker compose -f docker-compose-limit.yml up -d",
		"sys:info": "bun run scripts/sysinfo.ts",
		"test:up": "docker compose -f docker-compose-test.yml up -d",
		"bin:dev": "bun build --compile src/cli.ts --outfile dist/pulsar && cp ./dist/pulsar ~/.local/bin",
		"sync:vm": "UV_THREADPOOL_SIZE=2 taskset -c 0,1 nice -n 19 bun src/cli.ts sync -p 3 ads-staging.yml",
		"rm:folders": "rm -rf ./temp-dump ./logs",
		"bin:prod": "bun build --compile src/cli.ts --outfile dist/pulsar && chmod +x dist/pulsar",
		"up:pulsar": "bun rm:folders && docker compose -f docker-compose-dev.yml up --build -d && docker exec -it pulsar-dev sh",
		"clean:dev": "docker rm -f pulsar-dev mongo_test && docker rmi -f mongo-pulsar-app-dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.4",
		"@types/bun": "1.1.10",
		"@types/chalk": "^2.2.0",
		"@types/cli-progress": "^3.11.6",
		"@types/commander": "^2.12.2",
		"@types/figlet": "^1.5.8",
		"@types/js-yaml": "^4.0.9",
		"@types/mongodb": "^4.0.7",
		"@types/winston": "^2.4.4"
	},
	"peerDependencies": {
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"@types/date-fns": "^2.6.0",
		"bottleneck": "^2.19.5",
		"chalk": "^5.3.0",
		"cli-progress": "^3.12.0",
		"commander": "^12.1.0",
		"crc": "^4.3.2",
		"figlet": "^1.7.0",
		"js-yaml": "^4.1.0",
		"mongodb": "^6.9.0",
		"winston": "^3.14.2",
		"zod": "^4.0.15"
	}
}
